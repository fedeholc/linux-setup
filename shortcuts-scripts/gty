#!/bin/bash

# Intentamos dar foco a una instancia existente
if wmctrl -x -a ghostty; then
    exit 0
else
    # Si no existe, lanzamos Ghostty en segundo plano
    ghostty &

    # Esperamos a que la ventana aparezca (máximo 2 segundos)
    # Buscamos la clase 'ghostty' en la lista de ventanas
    for i in {1..20}; do
        if wmctrl -lx | grep -i "ghostty" > /dev/null; then
            # Una vez que aparece, le pedimos al gestor que le dé foco
            wmctrl -x -a ghostty
            break
        fi
        sleep 0.1
    done
fi
